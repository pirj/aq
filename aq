#!/usr/bin/env bash

# aq - QEMU wrapper to run Alpine Linux VMs on MacOS
# Usage: aq [new|start|stop|console|exec|scp|rm|ls] [args...]

[ -z "$DEBUG" ] || set -x
set -eu
set -o pipefail
set -fC

aq_help() {
  cat <<HELP
    aq new [-p host-port:vm-port ...] [vm-name]
    aq start vm-name
    aq stop vm-name
    aq console vm-name
    cat script.sh | aq exec vm-name
    aq exec vm-name nginx status
    aq exec vm-name < script.sh
    aq exec vm-name <<SH
      apk add nginx
      rc-service nginx start
    SH
    aq scp [-r] [-p] file1 file2... vm-name:/path
    aq scp [-r] [-p] vm-name:/file host-path
    aq rm vm-name
    aq ls
    aq --version
HELP
}

aq_version() {
  stderr aq $VERSION - QEMU wrapper to run Alpine Linux VMs on macOS and Linux
}

random_vm_name() {
  # Approximately 200K words, 2^32 random names
  shuf -n 2 /usr/share/dict/words | tr '\n' '-'| sed 's/-$//'
}

find_ovmf_code() {
  # Echo path to OVMF_CODE.fd, trying known locations across distros.
  local candidates=(
    /usr/share/OVMF/OVMF_CODE_4M.fd
    /usr/share/OVMF/OVMF_CODE.fd
    /usr/share/edk2/ovmf/OVMF_CODE.fd
    /usr/share/edk2/x64/OVMF_CODE.fd
    /usr/share/qemu/OVMF.fd
  )
  local p
  for p in "${candidates[@]}"; do
    [ -f "$p" ] && { echo "$p"; return 0; }
  done
  return 1
}

find_ovmf_vars() {
  # Echo path to OVMF_VARS.fd template (will be copied for read-write use).
  local candidates=(
    /usr/share/OVMF/OVMF_VARS_4M.fd
    /usr/share/OVMF/OVMF_VARS.fd
    /usr/share/edk2/ovmf/OVMF_VARS.fd
    /usr/share/edk2/x64/OVMF_VARS.fd
  )
  local p
  for p in "${candidates[@]}"; do
    [ -f "$p" ] && { echo "$p"; return 0; }
  done
  return 1
}

detect_host() {
  case "$(uname -s)" in
    Darwin)
      HOST_OS=darwin
      ARCH=aarch64
      ACCEL=hvf
      QEMU_BIN=qemu-system-aarch64
      MACHINE_OPTS="virt,highmem=on"
      UEFI_CODE="$(brew --prefix qemu 2>/dev/null)/share/qemu/edk2-aarch64-code.fd"
      UEFI_VARS_FLAVOR=sysbus_json
      CONSOLE=ttyAMA0
      ;;
    Linux)
      HOST_OS=linux
      ARCH=x86_64
      QEMU_BIN=qemu-system-x86_64
      MACHINE_OPTS="q35"
      CONSOLE=ttyS0
      UEFI_CODE=$(find_ovmf_code) || {
        echo "Error: OVMF firmware not found. Install package 'ovmf'." >&2
        exit 1
      }
      UEFI_VARS_FLAVOR=pflash_fd
      if [ -r /dev/kvm ] && [ -w /dev/kvm ]; then
        ACCEL=kvm
      elif [ -e /dev/kvm ]; then
        echo "Error: /dev/kvm exists but is not accessible." >&2
        echo "Hint: add your user to the 'kvm' group, then log out and back in:" >&2
        echo "  sudo usermod -aG kvm \$USER" >&2
        exit 1
      else
        echo "Error: /dev/kvm not found. KVM is required for aq on Linux." >&2
        echo "Hint: ensure your host supports virtualization (Intel VT-x / AMD-V)," >&2
        echo "      and that the kvm kernel modules are loaded:" >&2
        echo "  lsmod | grep kvm" >&2
        exit 1
      fi
      ;;
    *)
      echo "Error: unsupported host OS: $(uname -s). aq supports macOS (Darwin) and Linux." >&2
      exit 1
      ;;
  esac
}

# Parse a size argument like "8G" -> "8". Validates suffix is "G" and
# numeric part is a positive integer. Prints the integer or errors out.
parse_size_arg() {
  local arg="$1"
  case "$arg" in
    [1-9]G|[1-9][0-9]G|[1-9][0-9][0-9]G)
      echo "${arg%G}"
      ;;
    *)
      stderr "Error: invalid size '$arg'. Expected positive integer followed by G (e.g. 8G, 16G, 32G)."
      return 1
      ;;
  esac
}

# Parse a memory argument like "4G" -> "4". Same validation rules as
# parse_size_arg; kept as a separate function so callers can produce
# distinct error messages.
parse_memory_arg() {
  local arg="$1"
  case "$arg" in
    [1-9]G|[1-9][0-9]G|[1-9][0-9][0-9]G)
      echo "${arg%G}"
      ;;
    *)
      stderr "Error: invalid memory size '$arg'. Expected positive integer followed by G (e.g. 1G, 4G, 8G)."
      return 1
      ;;
  esac
}

# Compose a size-specific base filename.
# Usage: compute_base_filename <alpine-version> <arch> <size-int-G>
compute_base_filename() {
  local version="$1" arch="$2" size="$3"
  echo "alpine-base-${version}-${arch}-${size}G.raw"
}

# Emit qemu CLI fragment for UEFI variable storage, depending on host firmware flavor.
# Arg: directory containing the per-VM (or shared base) UEFI vars file.
uefi_vars_args() {
  local dir=$1
  case "$UEFI_VARS_FLAVOR" in
    sysbus_json)
      echo "-device uefi-vars-sysbus,jsonfile=$dir/uefi-vars.json"
      ;;
    pflash_fd)
      echo "-drive file=$dir/uefi-vars.fd,format=raw,if=pflash,unit=1"
      ;;
    *)
      echo "Error: unknown UEFI_VARS_FLAVOR: $UEFI_VARS_FLAVOR" >&2
      exit 1
      ;;
  esac
}

# Ensure UEFI vars storage exists for the given dir.
# For pflash_fd, copies a fresh OVMF_VARS.fd template.
# For sysbus_json, qemu creates the JSON file on first run.
ensure_uefi_vars() {
  local dir=$1
  case "$UEFI_VARS_FLAVOR" in
    sysbus_json)
      :
      ;;
    pflash_fd)
      if [ ! -f "$dir/uefi-vars.fd" ]; then
        local src
        src=$(find_ovmf_vars) || {
          echo "Error: OVMF_VARS.fd not found. Install package 'ovmf'." >&2
          exit 1
        }
        cp "$src" "$dir/uefi-vars.fd"
        chmod +w "$dir/uefi-vars.fd"
      fi
      ;;
  esac
}

migrate_base_dir_to_arch() {
  # One-time migration: ~/.local/share/aq/{alpine-base*.raw,alpine-virt*.iso,uefi-vars.json}
  # → ~/.local/share/aq/<arch>/...
  # Note: aq runs with `set -f` (no globbing), so we use `set +f` locally.
  [ ! -d "$BASE_DIR" ] && return 0
  local arch_dir="$BASE_DIR/$ARCH"

  local moved=0
  local removed=0
  set +f
  for f in "$BASE_DIR"/alpine-base-*.raw \
           "$BASE_DIR"/alpine-virt-*.iso \
           "$BASE_DIR"/alpine-virt-*.iso.asc \
           "$BASE_DIR"/uefi-vars.json; do
    [ -e "$f" ] || continue
    [ -d "$f" ] && continue
    local basename=$(basename "$f")
    if [ -e "$arch_dir/$basename" ]; then
      # Newer per-arch copy already exists; the old top-level file is an orphan.
      rm -f "$f"
      removed=1
    else
      mkdir -p "$arch_dir"
      mv "$f" "$arch_dir/"
      moved=1
    fi
  done
  set -f

  [ "$moved" = 1 ] && echo "aq: migrated base assets to $arch_dir" >&2
  [ "$removed" = 1 ] && echo "aq: removed orphaned base assets from $BASE_DIR (already present in $arch_dir)" >&2
  return 0
}

detect_host

VERSION=2.5.16

BASE_DIR=~/.local/share/aq
LATEST_ALPINE_VERSION=3.22.2
LATEST_ALPINE_MAJOR_MINOR=3.22
LATEST_ALPINE_ISO=alpine-virt-$LATEST_ALPINE_VERSION-$ARCH.iso

# Per-size base filename. Replaces the old LATEST_ALPINE_BASE constant.
# Args: <size-int-G>. Re-evaluated per call; do not capture into a variable
# that outlives the call (different VMs may have different sizes).
alpine_base_for_size() {
  compute_base_filename "$LATEST_ALPINE_VERSION" "$ARCH" "$1"
}

migrate_base_dir_to_arch

# --- Snapshot helpers ---------------------------------------------------------

snapshots_dir() {
  echo "$BASE_DIR/snapshots/$ARCH"
}

tags_dir() {
  echo "$BASE_DIR/tags/$ARCH"
}

snapshot_path() {
  local tag=$1
  echo "$(snapshots_dir)/$tag"
}

tag_path() {
  local name=$1
  echo "$(tags_dir)/$name"
}

snapshot_exists() {
  local tag=$1
  [ -d "$(snapshot_path "$tag")" ]
}

resolve_tag() {
  local input=$1
  if snapshot_exists "$input"; then
    echo "$input"
    return 0
  fi
  local link
  link=$(tag_path "$input")
  if [ -L "$link" ]; then
    basename "$(readlink "$link")"
    return 0
  fi
  return 1
}

# Atomically write meta.json. Args: <tag> <parent> <source_vm>.
write_meta() {
  local tag=$1 parent=$2 source_vm=$3 has_memory=${4:-false} base_image=${5:-unknown} boot_mode=${6:-unknown} ram_size_mb=${7:-}
  local dir
  dir=$(snapshot_path "$tag")
  local now
  now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  printf '{\n' > "$dir/meta.json.tmp"
  printf '  "tag": "%s",\n'         "$tag"                   >> "$dir/meta.json.tmp"
  printf '  "parent": "%s",\n'      "$parent"                >> "$dir/meta.json.tmp"
  printf '  "arch": "%s",\n'        "$ARCH"                  >> "$dir/meta.json.tmp"
  printf '  "base_image": "%s",\n'  "${base_image:-unknown}" >> "$dir/meta.json.tmp"
  printf '  "created": "%s",\n'     "$now"                   >> "$dir/meta.json.tmp"
  printf '  "last_used": "%s",\n'   "$now"                   >> "$dir/meta.json.tmp"
  printf '  "source_vm": "%s",\n'   "$source_vm"             >> "$dir/meta.json.tmp"
  printf '  "boot_mode": "%s",\n'   "$boot_mode"             >> "$dir/meta.json.tmp"
  if [ -n "$ram_size_mb" ]; then
    printf '  "ram_size_mb": %s,\n' "$ram_size_mb"           >> "$dir/meta.json.tmp"
  fi
  printf '  "has_memory": %s\n'     "$has_memory"            >> "$dir/meta.json.tmp"
  printf '}\n'                                               >> "$dir/meta.json.tmp"
  mv "$dir/meta.json.tmp" "$dir/meta.json"
}

# Read a single field from meta.json. Args: <tag> <field>.
read_meta() {
  local tag=$1 field=$2
  local file
  file=$(snapshot_path "$tag")/meta.json
  [ -f "$file" ] || return 1
  case "$field" in
    has_memory)
      grep -E '"has_memory":' "$file" | sed -E 's/.*"has_memory": (true|false).*/\1/' | head -1
      ;;
    ram_size_mb)
      grep -E '"ram_size_mb":' "$file" | sed -E 's/.*"ram_size_mb": ([0-9]+).*/\1/' | head -1
      ;;
    *)
      grep -E "\"$field\":" "$file" | sed -E "s/.*\"$field\": \"([^\"]*)\".*/\1/" | head -1
      ;;
  esac
}

# Count live dependents of a snapshot by scanning authoritative state:
#   1) VMs with .from_snapshot marker == <tag>
#   2) Other snapshots whose meta.json parent == <tag>
# This is the source of truth — no separate refcount file to drift.
get_refcount() {
  local tag=$1
  local count=0

  set +f
  if [ -d "$BASE_DIR" ]; then
    local vm_dir
    for vm_dir in "$BASE_DIR"/*/; do
      [ -d "$vm_dir" ] || continue
      local marker="$vm_dir/.from_snapshot"
      [ -f "$marker" ] || continue
      [ "$(cat "$marker")" = "$tag" ] && count=$((count + 1))
    done
  fi

  local snap_root
  snap_root=$(snapshots_dir)
  if [ -d "$snap_root" ]; then
    local snap_dir other_tag parent
    for snap_dir in "$snap_root"/*/; do
      [ -d "$snap_dir" ] || continue
      other_tag=$(basename "$snap_dir")
      [ "$other_tag" = "$tag" ] && continue
      parent=$(read_meta "$other_tag" parent 2>/dev/null || echo "")
      [ "$parent" = "$tag" ] && count=$((count + 1))
    done
  fi
  set -f

  echo "$count"
}

# --- end snapshot helpers -----------------------------------------------------

download_alpine_iso() {
  mkdir -p $BASE_DIR/$ARCH
  (
    cd $BASE_DIR/$ARCH
    if [ ! -f $LATEST_ALPINE_ISO ]; then
      wget https://dl-cdn.alpinelinux.org/alpine/v$LATEST_ALPINE_MAJOR_MINOR/releases/$ARCH/$LATEST_ALPINE_ISO
      wget https://dl-cdn.alpinelinux.org/alpine/v$LATEST_ALPINE_MAJOR_MINOR/releases/$ARCH/$LATEST_ALPINE_ISO.asc
      wget -qO- https://alpinelinux.org/keys/ncopa.asc | gpg --import
      if ! gpg --verify $LATEST_ALPINE_ISO.asc $LATEST_ALPINE_ISO; then
        echo "ERROR: Downloaded Apline ISO GPG signature verification failed!"
        rm -f $LATEST_ALPINE_ISO $LATEST_ALPINE_ISO.asc
        exit 1
      fi
    fi
  )
}

# Waits for certain input, can type, etc
wait_for() {
  SCRIPT=$1
  socat UNIX:command.sock PTY,link=command.pty &
  SOCAT_PID=$!

  # No --mute: surface the serial stream in stderr so cold-path
  # bootstrap output (setup-alpine progress, prompts, kernel messages)
  # is visible in logs — invaluable for debugging hangs across host
  # platforms / qemu versions / Alpine arches.
  tio \
    --script "$SCRIPT" \
    --script-run once \
    command.pty \
    --exec 'echo ""'

  kill $SOCAT_PID
}

ensure_base_image() {
  local size="$1"
  local fname; fname=$(alpine_base_for_size "$size")
  [ -f "$BASE_DIR/$ARCH/$fname" ] || bootstrap_base_image "$size"
}

bootstrap_base_image() {
  local size="$1"
  local fname; fname=$(alpine_base_for_size "$size")
  download_alpine_iso

  # Decide whether kernel/initramfs extraction is needed this run. If yes,
  # reserve a host port forwarded into the guest for a one-shot HTTP fetch.
  local need_extract=0
  local extract_port=""
  if [ ! -f "$BASE_DIR/$ARCH/vmlinuz-virt" ] || [ ! -f "$BASE_DIR/$ARCH/initramfs-virt" ]; then
    need_extract=1
    extract_port=$(random_port)
  fi

  (
    mkdir -p $BASE_DIR/$ARCH
    cd $BASE_DIR/$ARCH

    # Start from scratch
    rm -f "wip-$fname"
    rm -f uefi-vars.json uefi-vars.fd

    qemu-img create -f raw "wip-$fname" "${size}G" 1>/dev/null

    ensure_uefi_vars $BASE_DIR/$ARCH

    local nic_args="user,model=virtio-net-pci"
    [ "$need_extract" = "1" ] && nic_args="$nic_args,hostfwd=tcp::$extract_port-:8080"

    $QEMU_BIN \
      -machine $MACHINE_OPTS -accel $ACCEL -cpu host -m 1G \
      -drive file=$UEFI_CODE,format=raw,if=pflash,readonly=on,unit=0 \
      $(uefi_vars_args $BASE_DIR/$ARCH) \
      -drive if=virtio,file="$BASE_DIR/$ARCH/wip-$fname",format=raw,cache=none \
      -boot order=cd -cdrom $BASE_DIR/$ARCH/$LATEST_ALPINE_ISO \
      -nic $nic_args \
      -rtc base=utc,clock=host \
      -serial unix:$BASE_DIR/$ARCH/command.sock,server=on,wait=off,nodelay=on \
      -mon chardev=mon0,mode=readline -chardev socket,id=mon0,path=$BASE_DIR/$ARCH/control.sock,server=on,wait=off \
      -daemonize -pidfile $BASE_DIR/$ARCH/process.pid \
      -name wip-base-$LATEST_ALPINE_VERSION \
      -nographic \
      -parallel none \
      -monitor none

    # To debug, run:
    #   nc -U command.sock
    # or:
    #   socat STDIO UNIX:command.sock

    echo Booting up the base VM

    # Don't send a leading "\n" here: on slow firmware paths (notably
    # Linux/KVM + OVMF on GH actions runners) GRUB's "autoselect in 1s"
    # is still rendering when tio attaches. A stray "\n" cancels the
    # autoselect, leaving the boot stuck at the menu indefinitely.
    # Alpine's serial getty emits "localhost login: " on its own once
    # spawned; tio is attached long before then, so expect() matches
    # the natural prompt without any nudge.
    #
    # After write("root\n"), DO wait for the shell prompt before
    # returning. Without that second expect, wait_for races against
    # the guest's login/MOTD rendering and the next bootstrap
    # commands land before the shell is ready — getty/MOTD bytes
    # interleave with our long base64-encoded setup.conf line and
    # corrupt it, so setup-alpine falls back to interactive prompts
    # (ignoring -f /root/setup.conf), DISKOPTS isn't read, no disk
    # is installed, and kernel/initramfs extraction finds nothing.
    # Match the trailing `# ` of the root shell prompt — busybox
    # ash on Alpine live ISO is `localhost:~# `.
    #
    # NB: the Lua function is `write()` only in tio >= 3.8 (renamed
    # from `send` in v3.8 — see tio's release notes). aq requires
    # tio >= 3.8; setup-bakerish enforces this on Linux runners by
    # building a recent tio from source.
    wait_for 'expect("localhost login: "); write("root\n"); expect("# ", 30000)'

    echo  ..done

    echo Bootstrapping:

    # Build setup.conf locally on the host. This avoids sending a multi-line
    # heredoc into the live ISO's tty — busybox ash heredoc termination over
    # serial proved fragile (the SETUP-CONF terminator was not consistently
    # recognised on x86_64, leaving the shell stuck in a continuation prompt).
    SSH_PUB=$(ls $HOME/.ssh | grep '\.pub$' | head -1 | xargs -I_ cat $HOME/.ssh/_)
    SETUP_CONF=$(cat <<SETUP_CONF_END
KEYMAPOPTS=none

# Set hostname to 'alpine'
HOSTNAMEOPTS=alpine

# Set device manager to mdev
DEVDOPTS=mdev

# Contents of /etc/network/interfaces
INTERFACESOPTS="auto lo
iface lo inet loopback

auto eth0
iface eth0 inet dhcp
hostname alpine-test
"

# Search domain of example.com, Google public nameserver
# DNSOPTS="-d example.com 8.8.8.8"

# Set timezone to UTC
TIMEZONEOPTS="UTC"

# set http/ftp proxy
PROXYOPTS=none

# Add first mirror (CDN)
APKREPOSOPTS="-1"

# Create admin user
USEROPTS="-g floppy nouser"
ROOTSSHKEY="$SSH_PUB"

# Install Openssh
SSHDOPTS=openssh

# Use NTP
NTPOPTS="busybox"

# Use /dev/vda as a sys disk
DISKOPTS="-m sys /dev/vda"
SETUP_CONF_END
)
    SETUP_CONF_B64=$(printf '%s\n' "$SETUP_CONF" | base64 | tr -d '\n')

    # Bundle the bootstrap steps into a single multi-line script and
    # send it in ONE socat invocation. The busybox ash inside Alpine
    # reads stdin line-by-line and executes sequentially. This
    # eliminates two races that the previous three-separate-`echo |
    # socat STDIO` design hit on fast hosts (Linux/KVM CI runners):
    #
    #   1. Command-ordering race: between socat invocations the
    #      shell had a window to lose sync — input bytes could
    #      arrive interleaved with the previous line still being
    #      processed, the next line's prefix mixing into ongoing
    #      MOTD/echo output and corrupting the long base64.
    #   2. Reconnect race: qemu's serial chardev (server=on) takes
    #      a brief moment to mark the prior client as gone; rapid
    #      reconnects could be refused or wedge the chardev briefly.
    #
    # One send → one connection → guaranteed in-order delivery.
    # Combined with the post-login `expect("# ")` in wait_for above,
    # we're now timing-race-free up to the SETUP_ALPINE_OK sentinel.
    #
    # `yes ''` feeds an unbounded stream of blank lines (Enter)
    # which accept whatever default sits inside each `[...]`
    # bracket. Initial `echo y` covers the one disk-erase y/N
    # prompt that doesn't have a y/N default. Earlier `yes` (without
    # arg) was wrong: setup-interfaces asks "Which one do you want
    # to initialize? [eth0]" and "y" isn't a valid interface name,
    # so the prompt loops indefinitely.
    echo "  bootstrap: setup.conf + apk + setup-alpine (bundled)"
    echo "  awaiting SETUP_ALPINE_${ARCH}_OK"
    {
        printf 'echo %s | base64 -d > /root/setup.conf\n' "$SETUP_CONF_B64"
        printf 'apk add e2fsprogs\n'
        printf '{ echo y; yes ""; } | ROOTFS=ext4 setup-alpine -e -f /root/setup.conf\n'
        printf 'printf "SETUP_ALPINE_%%s_OK\\n" "$(uname -m)"\n'
    } | socat STDIO UNIX:command.sock

    wait_for "expect(\"SETUP_ALPINE_${ARCH}_OK\")"
    echo "  setup-alpine done"

    # Best-effort: clean up /root/setup.conf from the installed rootfs.
    # No serial-getty / grub-console hacks here — aq_start now uses SSH for
    # runtime, so the installed VM doesn't need a serial login prompt.
    #
    # We do NOT wait for a sentinel here. After setup-alpine returns, leftover
    # output from background subprocesses (kernel messages, udhcpc lease
    # renewal, progress-bar carriage returns from apk) can flood the serial
    # input loop and the shell echoes them back as "-sh: ^M: not found" for
    # minutes. The cleanup commands themselves are short; a brief sleep is
    # enough for them to land before we poweroff. If they don't land, the
    # only consequence is a stale /root/setup.conf inside the installed VM —
    # cosmetic, not a functional problem.
    # Guest-side cleanup applied inside /target before unmount:
    #   - rm setup.conf and .ash_history (cosmetic; setup.conf can leak
    #     the SSH pubkey, .ash_history would otherwise carry the install
    #     session's commands into every guest)
    #   - replace the stock Alpine /etc/motd (which advertises
    #     `setup-alpine`) with an aq-specific banner
    local cleanup
    cleanup='rm -f /target/root/setup.conf /target/root/.ash_history && printf "Welcome to your aq Alpine VM.\nDocs: https://github.com/pirj/aq\n" > /target/etc/motd'

    if [ "$need_extract" = "0" ]; then
      # Kernel files already cached for this arch — just run the cleanup
      # and unmount (matches the pre-extraction behaviour).
      echo "mkdir -p /target; mount /dev/vda3 /target; $cleanup; umount /target" | socat STDIO UNIX:command.sock
      sleep 2
    else
      stderr "Extracting kernel + initramfs (one-time per arch, ~10 s)..."

      # Mount the installed rootfs, run guest-side cleanup, and stream both
      # kernel and initramfs as a single tar over a netcat listener. This
      # uses only the live ISO's base busybox (tar + nc) — no apk add
      # required, no live-ISO repo state assumptions, no foreign packages.
      #
      # Root-partition index varies by arch: aarch64 setup-disk's sys-mode
      # layout differs from x86_64's (which can include a BIOS-boot
      # partition shifting the indices). Rather than hardcoding /dev/vdaN,
      # we mount-trial each /dev/vda* in turn and pick the one that
      # actually contains /boot/vmlinuz-virt. busybox blkid's
      # `-t TYPE=ext4` syntax isn't reliable across distros, so this
      # avoids it.
      #
      # The guest emits AQ_EXTRACT_READY just before starting `nc -l`. We
      # wait_for that sentinel from the host (capturing the full serial
      # stream in the process — visible in stderr for debugging) before
      # the host-side nc connects. That eliminates the previous 30×1s
      # blind-retry loop and makes any guest-side failure visible.
      guest_extract="\
mkdir -p /target
for p in /dev/vda*; do
  [ -b \"\$p\" ] || continue
  mount -t ext4 \"\$p\" /target 2>/dev/null || continue
  if [ -f /target/boot/vmlinuz-virt ]; then
    echo AQ_EXTRACT_PARTITION=\$p
    $cleanup
    echo AQ_EXTRACT_READY
    cd /target/boot && tar c vmlinuz-virt initramfs-virt | nc -l -p 8080
    umount /target
    exit 0
  fi
  umount /target 2>/dev/null
done
echo AQ_EXTRACT_NO_KERNEL_FOUND
exit 1"
      echo "$guest_extract" | socat STDIO UNIX:command.sock

      # Capture the guest serial up to AQ_EXTRACT_READY (or 30 s timeout).
      # Anything that goes wrong upstream — mount failures, missing
      # /boot/vmlinuz-virt, etc. — surfaces in the workflow log via
      # tio's stream because we dropped --mute in v2.5.10.
      wait_for 'expect("AQ_EXTRACT_READY", 30000)'

      # Fetch the tar stream from the hostfwd port. Just a couple of
      # quick retries — nc should already be listening because
      # AQ_EXTRACT_READY fired.
      mkdir -p "$BASE_DIR/$ARCH/wip-extract"
      attempt=0
      while [ $attempt -lt 5 ]; do
        if nc -w 30 127.0.0.1 "$extract_port" \
           | tar x -C "$BASE_DIR/$ARCH/wip-extract" 2>/dev/null ; then
          [ -f "$BASE_DIR/$ARCH/wip-extract/vmlinuz-virt" ] && \
          [ -f "$BASE_DIR/$ARCH/wip-extract/initramfs-virt" ] && break
        fi
        attempt=$((attempt + 1))
        sleep 1
      done

      # Sanity check: kernel + initramfs should be non-trivial in size.
      vsz=$(wc -c < "$BASE_DIR/$ARCH/wip-extract/vmlinuz-virt" 2>/dev/null || echo 0)
      isz=$(wc -c < "$BASE_DIR/$ARCH/wip-extract/initramfs-virt" 2>/dev/null || echo 0)
      if [ "$vsz" -lt 1000000 ] || [ "$isz" -lt 1000000 ]; then
        stderr "Error: kernel/initramfs extraction produced suspiciously small files (vmlinuz=$vsz, initramfs=$isz)."
        stderr "       Tar-over-nc extraction may have failed (nc unreachable, tar contents wrong)."
        rm -rf "$BASE_DIR/$ARCH/wip-extract"
        exit 1
      fi

      mv "$BASE_DIR/$ARCH/wip-extract/vmlinuz-virt"   "$BASE_DIR/$ARCH/vmlinuz-virt"
      mv "$BASE_DIR/$ARCH/wip-extract/initramfs-virt" "$BASE_DIR/$ARCH/initramfs-virt"
      rmdir "$BASE_DIR/$ARCH/wip-extract" 2>/dev/null || rm -rf "$BASE_DIR/$ARCH/wip-extract"
      chmod -w "$BASE_DIR/$ARCH/vmlinuz-virt" "$BASE_DIR/$ARCH/initramfs-virt"
      stderr "  ..done (vmlinuz=$vsz initramfs=$isz bytes)"
    fi

    echo poweroff | socat STDIO UNIX:command.sock

    # FIXME: does it power off immediately?

    echo quit | nc -U control.sock

    # FIXME: does it exit immediately? wait for command.sock to disappear?

    # OS installed, vars written. Time to set in stone.
    case "$UEFI_VARS_FLAVOR" in
      sysbus_json) chmod -w uefi-vars.json ;;
      pflash_fd)   chmod -w uefi-vars.fd ;;
    esac
    mv "$BASE_DIR/$ARCH/wip-$fname" "$BASE_DIR/$ARCH/$fname"
    chmod -w "$BASE_DIR/$ARCH/$fname"
  )
}

stderr() {
  echo "$@" >&2
}

# Parse `aq new` arguments. Sets module-level variables that aq_new reads:
#   FORWARDS (array), FROM_SNAPSHOT, COUNT, NEW_SIZE, NEW_MEMORY,
#   SKIP_FAST_BOOT, VM_NAME
# NEW_MEMORY is empty when not specified, so callers can distinguish
# "user didn't pass --memory" from "user explicitly chose 1G". Empty
# resolves to the snapshot's recorded ram_size_mb (for live restores) or
# the default 1G fallback.
# VM_NAME is the first positional argument (single-VM name OR prefix for
# --count path); empty if not provided.
# Validates and exits on error.
parse_new_args() {
  FORWARDS=()
  FROM_SNAPSHOT=""
  COUNT=1
  NEW_SIZE="2"
  NEW_MEMORY=""
  SKIP_FAST_BOOT=0
  VM_NAME=""

  while [ $# -gt 0 ]; do
    case "$1" in
      -p)
        FORWARDS+=("$2"); shift; shift
        ;;
      --from-snapshot=*)
        FROM_SNAPSHOT="${1#--from-snapshot=}"; shift
        ;;
      --from-snapshot)
        FROM_SNAPSHOT="$2"; shift; shift
        ;;
      --count=*)
        COUNT="${1#--count=}"; shift
        ;;
      --count)
        COUNT="$2"; shift; shift
        ;;
      --size=*)
        NEW_SIZE=$(parse_size_arg "${1#--size=}") || exit 1
        shift
        ;;
      --size)
        NEW_SIZE=$(parse_size_arg "$2") || exit 1
        shift; shift
        ;;
      --memory=*)
        NEW_MEMORY=$(parse_memory_arg "${1#--memory=}") || exit 1
        shift
        ;;
      --memory)
        NEW_MEMORY=$(parse_memory_arg "$2") || exit 1
        shift; shift
        ;;
      --skip-fast-boot)
        SKIP_FAST_BOOT=1; shift
        ;;
      *)
        break
        ;;
    esac
  done

  if [ $# -gt 0 ]; then
    VM_NAME="$1"
    shift
  fi
  if [ $# -gt 0 ]; then
    stderr "Error: unexpected extra arguments: $*"; exit 1
  fi
}

aq_new() {
  parse_new_args "$@"
  # parse_new_args populates FORWARDS, FROM_SNAPSHOT, COUNT, NEW_SIZE,
  # SKIP_FAST_BOOT, VM_NAME. Mirror to locals expected by the rest of aq_new
  # and by _aq_new_one (kept for now to minimise the diff; locals named in the
  # original style so the rest of the file reads unchanged).
  forwards=("${FORWARDS[@]:-}")
  local from_snapshot="$FROM_SNAPSHOT"
  local count="$COUNT"

  if ! [ "$count" -ge 1 ] 2>/dev/null; then
    stderr 'Error: --count must be a positive integer.'; exit 1
  fi

  if [ "$count" -gt 1 ] && [ -z "$from_snapshot" ]; then
    stderr 'Error: --count requires --from-snapshot=<tag>.'
    stderr 'Creating N VMs from a fresh base would still need first_boot_setup on each — use a snapshot.'
    exit 1
  fi

  # Single-VM path.
  if [ "$count" -eq 1 ]; then
    if [ -z "$VM_NAME" ]; then
      VM_NAME=$(random_vm_name)
    fi
    _aq_new_one "$from_snapshot" "$VM_NAME"
    stderr Created:
    echo $VM_NAME
    return 0
  fi

  # Counted path: <prefix>-0 .. <prefix>-(N-1).
  local prefix
  if [ -n "$VM_NAME" ]; then
    prefix="$VM_NAME"
  else
    prefix="shard-$$"
  fi

  stderr "Creating $count VMs as $prefix-0..$prefix-$((count-1))"
  local i=0
  while [ $i -lt $count ]; do
    _aq_new_one "$from_snapshot" "$prefix-$i"
    echo "$prefix-$i"
    i=$((i + 1))
  done
}

# Inner: create exactly one VM. Args: <from_snapshot-or-empty> <vm-name>.
_aq_new_one() {
  local from_snapshot=$1
  local vm_name=$2

  local backing_file backing_fmt
  if [ -n "$from_snapshot" ]; then
    local resolved
    resolved=$(resolve_tag "$from_snapshot") || {
      stderr "Error: snapshot or alias '$from_snapshot' does not exist."
      exit 1
    }
    backing_file="$(snapshot_path "$resolved")/disk.qcow2"
    backing_fmt=qcow2
    [ -f "$backing_file" ] || { stderr "Error: snapshot disk not found: $backing_file"; exit 1; }

    # Boot-mode compatibility check for live snapshots. Memory state is
    # tied to the kernel that produced it. Cold snapshots (no memory) work
    # under either boot mode.
    local snap_has_memory snap_boot_mode current_mode
    snap_has_memory=$(read_meta "$resolved" has_memory 2>/dev/null || echo false)
    snap_boot_mode=$(read_meta "$resolved" boot_mode 2>/dev/null || echo unknown)
    current_mode=direct
    [ "${SKIP_FAST_BOOT:-0}" = "1" ] && current_mode=uefi
    if [ "$snap_has_memory" = "true" ] \
       && [ "$snap_boot_mode" != "unknown" ] \
       && [ "$snap_boot_mode" != "$current_mode" ]; then
      stderr "Error: live snapshot '$resolved' was taken under boot_mode=$snap_boot_mode."
      stderr "       You are creating a VM under boot_mode=$current_mode."
      stderr "       Memory state is incompatible across boot modes."
      if [ "$snap_boot_mode" = "uefi" ]; then
        stderr "       Add --skip-fast-boot to match, or take a fresh cold snapshot."
      else
        stderr "       Drop --skip-fast-boot to match, or take a fresh cold snapshot."
      fi
      exit 1
    fi

    # RAM-size pinning for live snapshots. memory.bin was captured at the
    # source VM's exact -m value; loading it at a different size fails
    # opaquely in QEMU's migration code. If --memory wasn't passed, pick
    # up the snapshot's recorded ram_size_mb so it "just works".
    if [ "$snap_has_memory" = "true" ]; then
      local snap_ram_mb snap_ram_gb
      snap_ram_mb=$(read_meta "$resolved" ram_size_mb 2>/dev/null || echo "")
      if [ -n "$snap_ram_mb" ]; then
        snap_ram_gb=$((snap_ram_mb / 1024))
        if [ -z "$NEW_MEMORY" ]; then
          NEW_MEMORY="$snap_ram_gb"
        elif [ "$NEW_MEMORY" != "$snap_ram_gb" ]; then
          stderr "Error: live snapshot '$resolved' was captured at ${snap_ram_gb}G RAM."
          stderr "       Specified --memory=${NEW_MEMORY}G is incompatible (live snapshots bind RAM size)."
          stderr "       Drop --memory to auto-match, or take a fresh snapshot at the desired size."
          exit 1
        fi
      fi
    fi
  else
    ensure_base_image "${NEW_SIZE:-2}"
    backing_file="$BASE_DIR/$ARCH/$(alpine_base_for_size "${NEW_SIZE:-2}")"
    backing_fmt=raw
  fi

  # Default memory fallback (after snapshot logic above had a chance to set it).
  : "${NEW_MEMORY:=1}"

  if [ -d "$BASE_DIR/$vm_name" ]; then
    stderr "Error: VM '$vm_name' already exists."
    exit 1
  fi

  (
    cd $BASE_DIR
    mkdir $vm_name
    cd $vm_name
    touch hostfwd.conf
    if [ ${#forwards[@]} -gt 0 ]; then
      for forward in "${forwards[@]}"; do
        echo $forward >> hostfwd.conf
      done
    fi
    # Overlay size defaults to the backing's virtual size (qemu-img infers
    # it). For fresh-from-base that's the size-N base; for --from-snapshot
    # that's the snapshot disk's size. Either way, no resize2fs needed at
    # first boot.
    qemu-img create -b "$backing_file" -F "$backing_fmt" -f qcow2 storage.qcow2 1>/dev/null

    case "$UEFI_VARS_FLAVOR" in
      sysbus_json)
        cp $BASE_DIR/$ARCH/uefi-vars.json .
        chmod +w uefi-vars.json
        ;;
      pflash_fd)
        cp $BASE_DIR/$ARCH/uefi-vars.fd .
        chmod +w uefi-vars.fd
        ;;
    esac

    # Per-VM markers used by aq_start (boot path selection) and the disk-
    # full helper (size lookup).
    echo "${NEW_SIZE:-2}" > .size
    echo "${NEW_MEMORY:-1}" > .memory
    if [ "${SKIP_FAST_BOOT:-0}" = "1" ]; then
      touch .boot_mode_uefi
    else
      touch .boot_mode_direct
    fi

    # No .needs_first_boot_setup marker: size-N bases (used by both direct
    # and legacy UEFI paths since Phase 2) are pre-partitioned at full N,
    # so sfdisk + resize2fs at first boot would be a no-op. The
    # first_boot_setup function stays defined for backwards-compat with VMs
    # that still carry the marker from before Phase 2 — but we don't create
    # new VMs with it.
  )

  if [ -n "$from_snapshot" ]; then
    local resolved
    resolved=$(resolve_tag "$from_snapshot")
    echo "$resolved" > "$BASE_DIR/$vm_name/.from_snapshot"

    local has_memory
    has_memory=$(read_meta "$resolved" has_memory 2>/dev/null || echo false)
    if [ "$has_memory" = "true" ]; then
      # Prefer the zstd-compressed memory dump when present (saved by a
      # zstd-enabled snapshot create); aq_start detects the .zst suffix
      # and feeds QEMU via `-incoming exec:zstd -dc`.
      local src_zst="$(snapshot_path "$resolved")/memory.bin.zst"
      local src_plain="$(snapshot_path "$resolved")/memory.bin"
      if [ -f "$src_zst" ]; then
        local dst="$BASE_DIR/$vm_name/incoming-memory.bin.zst"
        ln "$src_zst" "$dst" 2>/dev/null || cp "$src_zst" "$dst"
      elif [ -f "$src_plain" ]; then
        local dst="$BASE_DIR/$vm_name/incoming-memory.bin"
        ln "$src_plain" "$dst" 2>/dev/null || cp "$src_plain" "$dst"
      fi
    fi
  fi
}

# Supports 2222:22, or just 22, returns formatted hostfwd=tcp::2222-:22
hostfwd_directive() {
  HOST_PORT=$(echo $1 | cut -d: -f1)
  GUEST_PORT=$(echo $1 | cut -d: -f2)
  echo hostfwd=::$HOST_PORT-:$GUEST_PORT
}

# Generate a random high port number for temporary SSH forwarding.
# Retries up to 20 times to avoid handing back a port that's already in use
# on the host (QEMU's hostfwd binds to 127.0.0.1 and silently fails on
# clashes). Uses `nc -z -w 1` since it's BSD/openbsd-portable; if nc
# connects, something is already listening on 127.0.0.1:<port>.
random_port() {
  local attempt=0 port
  while [ $attempt -lt 20 ]; do
    port=$(shuf -i 49152-65535 -n 1)
    if ! nc -z -w 1 127.0.0.1 "$port" 2>/dev/null; then
      echo "$port"
      return 0
    fi
    attempt=$((attempt + 1))
  done
  stderr "Error: failed to find a free random port after 20 attempts."
  return 1
}

# Get or generate a persistent SSH port for a VM
get_persistent_ssh_port() {
  VM_NAME=$1
  SSH_PORT_FILE="$BASE_DIR/$VM_NAME/ssh-port.conf"

  if [ -f "$SSH_PORT_FILE" ]; then
    cat "$SSH_PORT_FILE"
  else
    # Generate a new port and store it
    NEW_PORT=$(random_port)
    echo "$NEW_PORT" > "$SSH_PORT_FILE"
    echo "$NEW_PORT"
  fi
}

# Run an HMP command via the QMP wrapper. Returns when the HMP command
# completes. The QMP wire format is JSON; we send qmp_capabilities then
# the wrapped HMP command in a single connection.
#
# NOTE: HMP `migrate <uri>` is asynchronous over QMP — it returns
# "terminal does not allow synchronous migration, continuing detached".
# Use qmp_wait_migrate() after migrate to poll for completion.
qmp_hmp() {
  local sock=$1
  local hmp_cmd=$2
  local escaped
  escaped=$(printf '%s' "$hmp_cmd" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')
  printf '{"execute":"qmp_capabilities"}\n{"execute":"human-monitor-command","arguments":{"command-line":"%s"}}\n' \
    "$escaped" \
    | socat -t10 - "UNIX-CONNECT:$sock" 2>/dev/null
}

# Send a raw QMP command and read response. Args: <sock> <json-command>.
qmp_send() {
  local sock=$1
  local cmd=$2
  printf '{"execute":"qmp_capabilities"}\n%s\n' "$cmd" \
    | socat -t10 - "UNIX-CONNECT:$sock" 2>/dev/null
}

# Poll the VM status until it leaves the inmigrate state. After incoming
# migration applies, qemu transitions to paused (caller should send cont).
# Args: <sock>. Returns 0 when out of inmigrate, 1 on timeout.
#
# Bash case statements match top-down, first match wins, so the
# (inmigrate) case must come before the bare `paused` case — otherwise
# `*'VM status: paused'*` swallows `paused (inmigrate)` and the caller
# sends `cont` before migration finished. Caught on macOS HVF where
# migration is slow enough to be observable in the inmigrate state;
# Linux KVM was fast enough that the bug was latent (polling tended to
# catch the post-migrate window).
qmp_wait_migrate_incoming() {
  local sock=$1
  local max_attempts=${2:-300}
  local attempt=0
  while [ $attempt -lt $max_attempts ]; do
    local resp
    resp=$(qmp_hmp "$sock" 'info status' 2>/dev/null)
    case "$resp" in
      *'VM status: paused (inmigrate)'*) : ;;        # still migrating, keep waiting
      *'VM status: paused'*)             return 0 ;; # migration done, ready for cont
      *'VM status: running'*)            return 0 ;; # cont already happened (autocont)
    esac
    attempt=$((attempt + 1))
    sleep 0.2
  done
  stderr "Incoming migration did not apply after ${max_attempts} polls."
  return 1
}

# Poll query-migrate until the migration is "completed" or "failed".
# Args: <sock>. Returns 0 on completed, 1 on failed/timeout.
qmp_wait_migrate() {
  local sock=$1
  local max_attempts=${2:-300}   # 5 minutes worst case for large memory
  local attempt=0
  while [ $attempt -lt $max_attempts ]; do
    local resp
    resp=$(qmp_send "$sock" '{"execute":"query-migrate"}')
    case "$resp" in
      *'"status": "completed"'*) return 0 ;;
      *'"status": "failed"'*)
        stderr "QMP migrate failed: $resp"
        return 1
        ;;
    esac
    attempt=$((attempt + 1))
    sleep 0.5
  done
  stderr "QMP migrate did not complete after ${max_attempts} polls."
  return 1
}

# Add dynamic SSH port forwarding via QEMU monitor.
# Use socat with -t1 (linger 1s after EOF) so qemu has time to read the
# command before the connection is closed. Plain `nc -U` can race here.
# Also retry briefly because the monitor socket may not be ready
# immediately after qemu's -daemonize returns.
add_ssh_forward() {
  VM_NAME=$1
  HOST_PORT=$2
  local sock="$BASE_DIR/$VM_NAME/control.sock"
  local attempt=0
  while [ $attempt -lt 30 ]; do
    if [ -S "$sock" ] && \
       echo "hostfwd_add tcp::${HOST_PORT}-:22" | \
       socat -t1 - "UNIX-CONNECT:$sock" 2>/dev/null; then
      return 0
    fi
    attempt=$((attempt + 1))
    sleep 0.2
  done
  stderr "Error: failed to add SSH hostfwd via QEMU monitor after $attempt attempts."
  return 1
}

# Get SSH connection details for a VM
get_vm_ssh_details() {
  VM_NAME=$1
  SSH_PORT=$(get_persistent_ssh_port "$VM_NAME")
  echo "$SSH_PORT"
}

# Execute SSH command on VM with common options
vm_ssh() {
  VM_NAME=$1
  shift
  SSH_PORT=$(get_vm_ssh_details "$VM_NAME")
  ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$SSH_PORT" root@localhost "$@"
}

# Execute SCP command with VM using common options
vm_scp() {
  local vm_name="$1"
  shift
  local ssh_port=$(get_vm_ssh_details "$vm_name")
  scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -P "$ssh_port" "$@"
}

hostfwd() {
  VM_NAME=$1
  (
    cd $BASE_DIR/$VM_NAME
    directives=()
    for forward in $(cat hostfwd.conf); do
      directives+=($(hostfwd_directive $forward))
    done
    IFS=,
    if [ ${#directives[@]} -gt 0 ]; then
      echo "${directives[*]}"
    else
      echo ""
    fi
  )
}

vm_exists() {
  VM_NAME=$1
  [ -d "$BASE_DIR/$VM_NAME" ]
}

is_vm_running() {
  VM_NAME=$1
  [ -f "$BASE_DIR/$VM_NAME/process.pid" ] && kill -0 "$(cat "$BASE_DIR/$VM_NAME/process.pid" 2>/dev/null)" 2>/dev/null
}

first_boot_setup() {
  VM_NAME=$1
  vm_ssh "$VM_NAME" <<FIRST
hostname $VM_NAME
echo $VM_NAME > /etc/hostname
apk add partx sfdisk e2fsprogs-extra
echo ",+" | sfdisk --no-reread -N 3 /dev/vda --force
partx --update --nr 3 /dev/vda
resize2fs /dev/vda3
FIRST
}

# Poll SSH until the guest accepts a connection (or time out).
# Quiet on the warm-boot fast path: only narrates the wait once SSH hasn't
# come up within ~10s, so a successful start prints just "Started $vm".
#
# Probe cadence is 0.5s by default — tight enough that aq start returns
# within ~half a second of the guest actually being ready. With the prior
# 2s sleep, warm boots that finished mid-interval paid up to ~2s of dead
# wait. AQ_SSH_PROBE_INTERVAL overrides if the env wants a different
# cadence; max_attempts scales with it so the total budget stays ~3 min.
wait_for_ssh() {
  local vm_name=$1
  local probe_interval=${AQ_SSH_PROBE_INTERVAL:-0.5}
  # 360 * 0.5s = 3 min budget — same wall-clock ceiling as the old
  # 90 * 2s = 3 min, just with finer resolution.
  local max_attempts=${2:-360}
  local attempt=0
  local notified=0
  local ssh_port
  ssh_port=$(get_vm_ssh_details "$vm_name")
  while [ $attempt -lt $max_attempts ]; do
    if ssh -o StrictHostKeyChecking=no \
           -o UserKnownHostsFile=/dev/null \
           -o ConnectTimeout=1 \
           -o LogLevel=ERROR \
           -p "$ssh_port" root@localhost true 2>/dev/null; then
      [ "$notified" = 1 ] && stderr "SSH ready on $vm_name after $attempt attempts."
      return 0
    fi
    attempt=$((attempt + 1))
    # ~10 s with the default 0.5 s cadence — same threshold as before
    # for the "this is taking a while" notification.
    if [ "$notified" = 0 ] && [ $attempt -ge 20 ]; then
      stderr "Waiting for SSH on $vm_name (port $ssh_port)..."
      notified=1
    fi
    # Periodic heartbeat every ~20 s so CI logs show progress.
    [ $((attempt % 40)) = 0 ] && stderr "  ...still waiting for SSH ($attempt/$max_attempts)"
    sleep "$probe_interval"
  done
  stderr "Error: SSH on $vm_name (port $ssh_port) not reachable after $max_attempts attempts."
  stderr "Diagnostics:"
  stderr "  process.pid=$(cat $BASE_DIR/$vm_name/process.pid 2>/dev/null)"
  stderr "  is_vm_running=$(is_vm_running $vm_name && echo yes || echo no)"
  stderr "  netstat (host listening on $ssh_port):"
  netstat -an 2>&1 | grep ":$ssh_port " | head -3 >&2 || true
  stderr "  ssh -v output:"
  ssh -vv -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
      -o ConnectTimeout=5 -p "$ssh_port" root@localhost true 2>&1 | head -30 >&2 || true
  return 1
}

aq_start() {
  VM_NAME=${1:-}
  [ -z "$VM_NAME" ] && stderr 'Error: VM name required: `aq start <vm-name>`.' && exit 1
  ! vm_exists "$VM_NAME" && stderr "Error: VM '$VM_NAME' does not exist." && exit 1

  # Check if VM is already running
  if is_vm_running "$VM_NAME"; then
    stderr "Error: VM '$VM_NAME' is already running."
    exit 1
  fi

  HOST_FORWARDS="$(hostfwd $VM_NAME)"

  # If a memory snapshot was staged on aq_new --from-snapshot (or by an
  # external orchestrator like rlock writing the file directly into the
  # VM dir), ask qemu to restore from it.
  #
  # Two on-disk forms are supported:
  #   * incoming-memory.bin.zst — fed via `-incoming exec:zstd -dc <file>`.
  #     QEMU streams from zstd's stdout; no temp materialisation. zstd
  #     decompression is multi-core (~1 GB/s aggregate on M3) and runs
  #     in parallel with QEMU's migration apply.
  #   * incoming-memory.bin     — fed via the simple `file:` URI.
  #
  # `-incoming exec:` takes a single command-line string; the array form
  # below keeps the space-containing URI as one arg through the qemu
  # invocation. Empty array on no-incoming expands cleanly under set -u.
  local -a incoming_args=()
  local incoming_file_zst="$BASE_DIR/$VM_NAME/incoming-memory.bin.zst"
  local incoming_file_plain="$BASE_DIR/$VM_NAME/incoming-memory.bin"
  if [ -f "$incoming_file_zst" ]; then
    if ! command -v zstd >/dev/null 2>&1; then
      stderr "Error: $incoming_file_zst present but zstd not installed on the host."
      stderr "  Either: brew install zstd, or remove the .zst and rely on a plain memory.bin."
      exit 1
    fi
    incoming_args=(-incoming "exec:zstd -dc $incoming_file_zst")
  elif [ -f "$incoming_file_plain" ]; then
    incoming_args=(-incoming "file:$incoming_file_plain")
  fi

  # Boot mode selection: direct kernel boot is the default (post Phase 2);
  # UEFI is the fallback retained via --skip-fast-boot at aq new time.
  # Use a bash array so the -append value stays a single argument.
  local -a boot_args
  if [ -f "$BASE_DIR/$VM_NAME/.boot_mode_direct" ] \
     && [ -f "$BASE_DIR/$ARCH/vmlinuz-virt" ] \
     && [ -f "$BASE_DIR/$ARCH/initramfs-virt" ]; then
    # AQ_KERNEL_APPEND_EXTRA: appended to the kernel cmdline. Used by the
    # benchmark harness to A/B knobs like `noapic` or `tsc=reliable` without
    # forking the script. Production VMs leave it unset.
    local kernel_append="console=$CONSOLE root=/dev/vda3 rootfstype=ext4 modules=ext4,virtio-pci rw quiet"
    [ -n "${AQ_KERNEL_APPEND_EXTRA:-}" ] && kernel_append="$kernel_append ${AQ_KERNEL_APPEND_EXTRA}"
    boot_args=(
      -kernel "$BASE_DIR/$ARCH/vmlinuz-virt"
      -initrd "$BASE_DIR/$ARCH/initramfs-virt"
      -append "$kernel_append"
    )
  else
    boot_args=(
      -drive "file=$UEFI_CODE,format=raw,if=pflash,readonly=on,unit=0"
    )
    # uefi_vars_args emits space-separated tokens. Read into the array.
    local _uefi_args
    _uefi_args=$(uefi_vars_args "$BASE_DIR/$VM_NAME")
    # shellcheck disable=SC2206  # intentional word-split
    boot_args+=($_uefi_args)
    boot_args+=(-boot order=d)
  fi

  # Read the VM's chosen RAM size. Falls back to 1G for VMs created
  # before this version of aq (no .memory marker file).
  local vm_memory_g
  vm_memory_g=$(cat "$BASE_DIR/$VM_NAME/.memory" 2>/dev/null || echo "1")

  # Benchmark/perf-tuning hooks (left unset in production):
  #   AQ_DRIVE_EXTRA       — appended to the storage `-drive` directive
  #                          (e.g. ",aio=io_uring,cache.direct=on")
  #   AQ_QEMU_EXTRA_ARGS   — extra raw QEMU args (e.g. "-smp 2")
  #   AQ_MACHINE_OVERRIDE  — replaces $MACHINE_OPTS for this run
  local machine_opts="${AQ_MACHINE_OVERRIDE:-$MACHINE_OPTS}"
  $QEMU_BIN \
    -machine $machine_opts -accel $ACCEL -cpu host -m "${vm_memory_g}G" \
    "${boot_args[@]}" \
    -drive if=virtio,file=$BASE_DIR/$VM_NAME/storage.qcow2${AQ_DRIVE_EXTRA:-} \
    -nic user,model=virtio-net-pci,$HOST_FORWARDS \
    -rtc base=utc,clock=host \
    -serial unix:$BASE_DIR/$VM_NAME/command.sock,server=on,wait=off,nodelay=on \
    -mon chardev=mon0,mode=readline -chardev socket,id=mon0,path=$BASE_DIR/$VM_NAME/control.sock,server=on,wait=off \
    -qmp unix:$BASE_DIR/$VM_NAME/qmp.sock,server=on,wait=off \
    -daemonize -pidfile $BASE_DIR/$VM_NAME/process.pid \
    -name $VM_NAME \
    -display none \
    -parallel none \
    -monitor none \
    "${incoming_args[@]}" ${AQ_QEMU_EXTRA_ARGS:-}

  # qemu started with -incoming sits in inmigrate/paused state. Wait for the
  # migration to apply, then resume the CPU and verify the VM is actually
  # running. Retry cont if needed — sending cont during the final inmigrate
  # → paused transition can no-op in some qemu versions.
  if [ ${#incoming_args[@]} -gt 0 ]; then
    local qmp_sock="$BASE_DIR/$VM_NAME/qmp.sock"
    if ! qmp_wait_migrate_incoming "$qmp_sock"; then
      stderr "Error: incoming migration did not complete; the VM may be in a bad state."
      # Known upstream QEMU bug on macOS aarch64 + QEMU 11.0.0: ARM target
      # asserts during incoming migration (target/arm/machine.c:1045,
      # cpu_pre_load !cpreg_vmstate_indexes). Hint the user at the workaround
      # so they don't waste time bisecting their own setup.
      if [ "$HOST_OS" = darwin ] && [ "$ARCH" = aarch64 ] \
         && "$QEMU_BIN" --version 2>/dev/null | head -1 | grep -qE 'version 11\.0\.0( |$)'; then
        stderr ""
        stderr "Hint: this is the known QEMU 11.0.0 aarch64 HVF live-restore regression."
        stderr "  Easiest fix — if /opt/homebrew/Cellar/qemu/10.0.3 is still around (left over"
        stderr "  from a recent brew upgrade), PATH-prepend it:"
        stderr "    export PATH=\"/opt/homebrew/Cellar/qemu/10.0.3/bin:\$PATH\""
        stderr "  Otherwise: brew install + use whatever 10.x is currently the latest qemu@10"
        stderr "  in homebrew-core, or wait for QEMU 11.1.0 to ship the upstream fix."
        stderr "  See README Troubleshooting for details."
      fi
      exit 1
    fi
    local cont_attempt=0
    while [ $cont_attempt -lt 30 ]; do
      qmp_hmp "$qmp_sock" 'cont' >/dev/null
      sleep 0.2
      local status_resp
      status_resp=$(qmp_send "$qmp_sock" '{"execute":"query-status"}')
      case "$status_resp" in
        *'"running": true'*) break ;;
      esac
      cont_attempt=$((cont_attempt + 1))
    done
    if [ $cont_attempt -ge 30 ]; then
      stderr "Error: VM did not transition to running after $cont_attempt cont attempts."
      exit 1
    fi
    # Consumed by qemu — remove both possible forms.
    rm -f "$incoming_file_plain" "$incoming_file_zst"
  fi

  # Set up persistent SSH forwarding before waiting — SSH polling needs it.
  SSH_PORT=$(get_persistent_ssh_port "$VM_NAME")
  add_ssh_forward "$VM_NAME" "$SSH_PORT"

  # Wait for SSH to be reachable in the guest.
  wait_for_ssh "$VM_NAME" || exit 1

  # Check if first boot setup is needed
  FIRST_BOOT_MARKER="$BASE_DIR/$VM_NAME/.needs_first_boot_setup"
  if [ -f "$FIRST_BOOT_MARKER" ]; then
    stderr "First boot detected, performing automated setup..."
    first_boot_setup "$VM_NAME"
    rm "$FIRST_BOOT_MARKER"
  fi

  stderr Started $VM_NAME
}

aq_stop() {
  VM_NAME=${1:-}
  [ -z "$VM_NAME" ] && stderr 'Error: VM name required: `aq stop <vm-name>`.' && exit 1
  ! vm_exists "$VM_NAME" && stderr "Error: VM '$VM_NAME' does not exist." && exit 1

  # Flush guest filesystem caches via SSH before killing qemu so disk state is
  # consistent on next start (and durable for snapshotting).
  if is_vm_running "$VM_NAME"; then
    vm_ssh "$VM_NAME" 'sync && sync' 2>/dev/null || true
  fi

  # Clean up SSH port allocation file
  rm -f "$BASE_DIR/$VM_NAME/ssh-port.conf"

  if is_vm_running "$VM_NAME"; then
    echo quit | nc -U $BASE_DIR/$VM_NAME/control.sock 1>/dev/null
  fi
}

# Wait for first boot setup to complete before allowing exec/console
wait_for_first_boot() {
  VM_NAME=$1
  FIRST_BOOT_MARKER="$BASE_DIR/$VM_NAME/.needs_first_boot_setup"

  if [ -f "$FIRST_BOOT_MARKER" ]; then
    stderr "Waiting for first boot setup to complete..."
    ATTEMPTS=0
    MAX_ATTEMPTS=60  # 60 * 0.5s = 30 seconds
    while [ -f "$FIRST_BOOT_MARKER" ] && [ $ATTEMPTS -lt $MAX_ATTEMPTS ]; do
      sleep 0.5
      stderr -n "."
      ATTEMPTS=$((ATTEMPTS + 1))
    done
    stderr ""

    if [ -f "$FIRST_BOOT_MARKER" ]; then
      stderr "Warning: First boot setup timeout after 30 seconds, proceeding anyway..."
    fi
  fi
}

aq_console() {
  VM_NAME=${1:-}
  [ -z "$VM_NAME" ] && stderr 'Error: VM name required: `aq console <vm-name>`.' && exit 1
  ! vm_exists "$VM_NAME" && stderr "Error: VM '$VM_NAME' does not exist." && exit 1
  if ! is_vm_running "$VM_NAME"; then
    stderr "Error: VM '$VM_NAME' is not running. Start it with: aq start $VM_NAME"
    exit 1
  fi
  wait_for_first_boot "$VM_NAME"

  vm_ssh "$VM_NAME"
}

emit_disk_full_help() {
  local vm_name="$1" size="$2"
  cat >&2 <<EOM

ERROR: VM '$vm_name' is out of disk space (current: ${size}G).

To recreate this VM with more space:

  aq rm $vm_name
  aq new --size=$((size * 2))G $vm_name     # or 16G, 32G, etc.

If the requested-size base doesn't exist yet, this builds it once
(~30 s). Every subsequent aq new --size=$((size * 2))G is fast.

Per-VM resize (existing data preserved) is also possible but trickier:

  qemu-img resize $BASE_DIR/$vm_name/storage.qcow2 +${size}G
  aq exec $vm_name "growpart /dev/vda 3 && resize2fs /dev/vda3"
  # Requires e2fsprogs-extra + cloud-utils-growpart inside the guest;
  # they're not preinstalled in the base.
EOM
}

aq_exec() {
  VM_NAME=${1:-}
  [ -z "$VM_NAME" ] && stderr 'Error: VM name required: `aq exec <vm-name>`.' && exit 1
  ! vm_exists "$VM_NAME" && stderr "Error: VM '$VM_NAME' does not exist." && exit 1
  if ! is_vm_running "$VM_NAME"; then
    stderr "Error: VM '$VM_NAME' is not running. Start it with: aq start $VM_NAME"
    exit 1
  fi
  wait_for_first_boot "$VM_NAME"
  shift

  # Capture stderr to a temp file so we can scan it for disk-full markers
  # after the command finishes. Stderr is replayed to the terminal at the
  # end — not real-time — to keep this compatible with aq's `set -fC`
  # (noclobber) without resorting to process substitution.
  local err_log
  err_log=$(mktemp)

  local rc=0
  # `>|` overrides the script-level `set -fC` noclobber so we can write
  # to the mktemp'd file (which already exists).
  if [ $# -gt 0 ]; then # Have command-line arguments - execute them as a command
    vm_ssh "$VM_NAME" "$@" 2>| "$err_log" || rc=$?
  elif [ ! -t 0 ]; then # No arguments, have stdin - execute it as a script
    vm_ssh "$VM_NAME" 'sh -s' 2>| "$err_log" || rc=$?
  else
    stderr 'Error: No command or stdin provided. Usage: `aq exec <vm-name> [command]` or pipe input.'
    rm -f "$err_log"
    exit 1
  fi

  # Replay captured stderr to the terminal.
  [ -s "$err_log" ] && cat "$err_log" >&2

  # Surface the disk-full helper if the command output contains a clear
  # ENOSPC indicator. Strong-match only, to avoid false positives.
  if [ "$rc" -ne 0 ] && grep -qE 'No space left on device|EXT4-fs.*ENOSPC' "$err_log" 2>/dev/null; then
    local vm_size
    vm_size=$(cat "$BASE_DIR/$VM_NAME/.size" 2>/dev/null || echo 2)
    emit_disk_full_help "$VM_NAME" "$vm_size"
  fi
  rm -f "$err_log"
  return "$rc"
}

aq_scp() {
  [ $# -lt 2 ] && stderr 'Error: At least source and destination required. Usage: `aq scp [-r] [-p] source... destination`.' && exit 1

  local scp_opts=("-B")
  local sources=()
  local destination=""
  local vm_name=""
  local is_vm_to_host=false

  # Parse options (-r, -p, etc.)
  while [[ $# -gt 0 && $1 == -* ]]; do
    scp_opts+=("$1")
    shift
  done

  [ $# -lt 2 ] && stderr 'Error: At least source and destination required after options.' && exit 1

  # Last argument is destination
  destination="${@: -1}"
  # All but last are sources
  sources=("${@:1:$(($#-1))}")

  # Determine direction and extract VM name
  if [[ "$destination" == *:* ]]; then
    # Host to VM
    vm_name="${destination%%:*}"
    [ -z "$vm_name" ] && stderr 'Error: VM name required in destination.' && exit 1

    # Validate all sources are on host (no colons)
    for source in "${sources[@]}"; do
      if [[ "$source" == *:* ]]; then
        stderr 'Error: Cannot mix VM and host sources when copying to VM.' && exit 1
      fi
    done
  else
    # VM to host
    is_vm_to_host=true

    # First source must contain VM name
    first_source="${sources[0]}"
    if [[ "$first_source" != *:* ]]; then
      stderr 'Error: First source must specify VM name (vm-name:/path) when destination is on host.' && exit 1
    fi

    vm_name="${first_source%%:*}"
    [ -z "$vm_name" ] && stderr 'Error: VM name required in first source.' && exit 1

    # Validate remaining sources
    for source in "${sources[@]:1}"; do
      if [[ "$source" == *:* ]]; then
        source_vm="${source%%:*}"
        if [ -n "$source_vm" ] && [ "$source_vm" != "$vm_name" ]; then
          stderr "Error: Inconsistent VM names: '$vm_name' vs '$source_vm'." && exit 1
        fi
      else
        stderr 'Error: All sources must be VM paths (vm-name:/path or :/path) when destination is on host.' && exit 1
      fi
    done

    # Normalize sources - prepend vm_name to those starting with ":"
    local normalized_sources=()
    for source in "${sources[@]}"; do
      if [[ "$source" == :* ]]; then
        normalized_sources+=("${vm_name}${source}")
      else
        normalized_sources+=("$source")
      fi
    done
    sources=("${normalized_sources[@]}")
  fi

  # Check if VM exists
  ! vm_exists "$vm_name" && stderr "Error: VM '$vm_name' does not exist." && exit 1
  if ! is_vm_running "$vm_name"; then
    stderr "Error: VM '$vm_name' is not running. Start it with: aq start $vm_name"
    exit 1
  fi

  # Convert VM paths to use localhost with SSH port
  local scp_sources=()
  local scp_destination="$destination"

  if [ "$is_vm_to_host" = true ]; then
    # Convert VM sources to SSH format
    for source in "${sources[@]}"; do
      if [[ "$source" == *:* ]]; then
        vm_path="${source#*:}"
        scp_sources+=("root@localhost:${vm_path}")
      fi
    done
  else
    # Host to VM - convert destination
    vm_path="${destination#*:}"
    scp_destination="root@localhost:${vm_path}"
    scp_sources=("${sources[@]}")
  fi

  # Execute scp command using helper
  vm_scp "$vm_name" "${scp_opts[@]}" "${scp_sources[@]}" "$scp_destination"
}

aq_rm() {
  VM_NAME=${1:-}
  [ -z "$VM_NAME" ] && stderr 'Error: VM name required: `aq rm <vm-name>`.' && exit 1
  ! vm_exists "$VM_NAME" && stderr "Error: VM '$VM_NAME' does not exist." && exit 1

  aq_stop $VM_NAME
  rm -rf $BASE_DIR/$VM_NAME
  stderr "Removed" $VM_NAME
}

aq_snapshot_create() {
  local vm_name=${1:-}
  local tag=${2:-}
  [ -z "$vm_name" ] && stderr 'Error: VM name required: `aq snapshot create <vm-name> <tag>`.' && exit 1
  [ -z "$tag" ]     && stderr 'Error: tag required: `aq snapshot create <vm-name> <tag>`.' && exit 1
  ! vm_exists "$vm_name" && stderr "Error: VM '$vm_name' does not exist." && exit 1
  if snapshot_exists "$tag"; then
    stderr "Error: snapshot '$tag' already exists. Pick a new tag or remove the existing one with: aq snapshot rm $tag"
    exit 1
  fi

  local source_disk="$BASE_DIR/$vm_name/storage.qcow2"
  [ -f "$source_disk" ] || { stderr "Error: source disk not found: $source_disk"; exit 1; }

  # Determine parent: read the qcow2 backing-file basename.
  # --force-share lets us read while the VM holds an exclusive lock.
  # `|| true` so an empty backing chain (parent=base case) doesn't trip set -e
  # via grep's no-match exit code under pipefail.
  local backing
  backing=$( { qemu-img info --force-share --output=json "$source_disk" 2>/dev/null \
            | grep -E '"backing-filename":' \
            | sed -E 's/.*"backing-filename": "([^"]*)".*/\1/' \
            | head -1; } || true )
  local parent="base"
  local base_image_name=""
  if [ -n "$backing" ]; then
    case "$backing" in
      */alpine-base-*-"$ARCH"-*G.raw)
        parent="base"
        base_image_name="${backing##*/}"
        ;;
      *snapshots/*/disk.qcow2)
        parent=$(echo "$backing" | sed -E 's|.*/snapshots/[^/]+/([^/]+)/disk.qcow2|\1|')
        ;;
      *)
        parent="unknown"
        ;;
    esac
  fi

  local snap_dir
  snap_dir=$(snapshot_path "$tag")
  mkdir -p "$snap_dir"

  local has_memory=false
  if is_vm_running "$vm_name"; then
    # Live snapshot: pause, dump memory, copy disk, resume.
    local qmp_sock="$BASE_DIR/$vm_name/qmp.sock"
    [ -S "$qmp_sock" ] || { stderr "Error: QMP socket missing for running VM '$vm_name'. Restart the VM with this version of aq first."; rm -rf "$snap_dir"; exit 1; }

    stderr "Live snapshot: pausing VM..."
    vm_ssh "$vm_name" 'sync && sync' 2>/dev/null || true
    qmp_hmp "$qmp_sock" 'stop' >/dev/null

    stderr "Live snapshot: capturing memory state..."
    # Use the file: migration URI: no spaces, no shell escaping, no eval.
    qmp_hmp "$qmp_sock" "migrate file:$snap_dir/memory.bin" >/dev/null
    if ! qmp_wait_migrate "$qmp_sock"; then
      stderr "Error: live memory capture failed; resuming VM and removing partial snapshot."
      qmp_hmp "$qmp_sock" 'cont' >/dev/null
      rm -rf "$snap_dir"
      exit 1
    fi

    stderr "Live snapshot: copying disk..."
    cp "$source_disk" "$snap_dir/disk.qcow2"

    stderr "Live snapshot: resuming VM..."
    qmp_hmp "$qmp_sock" 'cont' >/dev/null

    # Compress memory.bin with zstd (multi-threaded). RAM dumps are
    # very compressible — zero pages, page cache, repeated kernel
    # structures typically yield 3-5× on real workloads. Save-side
    # cost is a few seconds on M3; restore-side cost is the price of
    # pipe-based migration via `-incoming exec:zstd -dc`, measured at
    # ~370 ms on the rails-pg-sample fixture vs `-incoming file:`.
    #
    # Trade-off: disk vs warm-restore time.
    #   * Multi-project laptops: disk savings (~1.1 GB per live layer)
    #     dominate, since the warm penalty is a one-off per `rl new`.
    #   * Single-project CI runners that warm-restore the same VM many
    #     times per cache key: the warm penalty multiplies; the disk
    #     saving is one-shot. They can opt out with
    #     AQ_NO_SNAPSHOT_COMPRESS=1 — aq writes plain memory.bin and
    #     aq_start uses `-incoming file:` (the older fast path).
    #
    # If zstd isn't installed, behaves the same as the opt-out: leave
    # plain memory.bin.
    if [ "${AQ_NO_SNAPSHOT_COMPRESS:-}" = "1" ]; then
      stderr "Live snapshot: AQ_NO_SNAPSHOT_COMPRESS=1 — leaving memory.bin uncompressed."
    elif command -v zstd >/dev/null 2>&1; then
      stderr "Live snapshot: compressing memory state (zstd)..."
      zstd -T0 -q --rm "$snap_dir/memory.bin" -o "$snap_dir/memory.bin.zst"
    else
      stderr "Live snapshot: zstd not installed — leaving memory.bin uncompressed."
    fi

    has_memory=true
  else
    # Cold snapshot (Phase 2A behaviour).
    cp "$source_disk" "$snap_dir/disk.qcow2"
  fi

  # Read the source VM's boot mode so the snapshot records compatibility.
  local snap_boot_mode="unknown"
  if [ -f "$BASE_DIR/$vm_name/.boot_mode_direct" ]; then
    snap_boot_mode=direct
  elif [ -f "$BASE_DIR/$vm_name/.boot_mode_uefi" ]; then
    snap_boot_mode=uefi
  fi

  # For live snapshots, record the source VM's RAM size in MB so we can
  # refuse opaque QEMU migration failures on restore. Pre-snapshot-kind
  # VMs may lack a .memory marker; fall back to 1G.
  local snap_ram_size_mb=""
  if [ "$has_memory" = "true" ]; then
    local vm_mem_g
    vm_mem_g=$(cat "$BASE_DIR/$vm_name/.memory" 2>/dev/null || echo "1")
    snap_ram_size_mb=$((vm_mem_g * 1024))
  fi

  write_meta "$tag" "$parent" "$vm_name" "$has_memory" "$base_image_name" "$snap_boot_mode" "$snap_ram_size_mb"

  if [ "$has_memory" = true ]; then
    stderr "Snapshot created: $tag (parent: $parent, with memory)"
  else
    stderr "Snapshot created: $tag (parent: $parent)"
  fi
}

aq_snapshot_ls() {
  local dir
  dir=$(snapshots_dir)
  [ -d "$dir" ] || return 0

  printf "%-30s %-20s %-7s %-6s %-20s %s\n" "TAG" "PARENT" "REFS" "SIZE" "CREATED" "SOURCE_VM"
  set +f
  for snap_dir in "$dir"/*/; do
    [ -d "$snap_dir" ] || continue
    local tag
    tag=$(basename "$snap_dir")
    local parent created source_vm refs size
    parent=$(read_meta "$tag" parent 2>/dev/null || echo "?")
    created=$(read_meta "$tag" created 2>/dev/null || echo "?")
    source_vm=$(read_meta "$tag" source_vm 2>/dev/null || echo "?")
    refs=$(get_refcount "$tag")
    size=$(du -h "$snap_dir/disk.qcow2" 2>/dev/null | awk '{print $1}')
    printf "%-30s %-20s %-7s %-6s %-20s %s\n" "$tag" "$parent" "$refs" "${size:-?}" "$created" "$source_vm"
  done
  set -f
}

aq_snapshot_rm() {
  local force=0
  if [ "${1:-}" = "--force" ]; then
    force=1
    shift
  fi
  local tag=${1:-}
  [ -z "$tag" ] && stderr 'Error: tag required: `aq snapshot rm [--force] <tag>`.' && exit 1
  if ! snapshot_exists "$tag"; then
    stderr "Error: snapshot '$tag' does not exist."
    exit 1
  fi
  local refs
  refs=$(get_refcount "$tag")
  if [ "$refs" -gt 0 ] && [ "$force" -eq 0 ]; then
    stderr "Error: snapshot '$tag' has $refs reference(s). Use --force to remove anyway, or remove dependents first."
    exit 1
  fi

  set +f
  for link in "$(tags_dir)"/*; do
    [ -L "$link" ] || continue
    local target
    target=$(readlink "$link")
    if [ "$(basename "$target")" = "$tag" ]; then
      rm -f "$link"
    fi
  done
  set -f

  rm -rf "$(snapshot_path "$tag")"
  stderr "Snapshot removed: $tag"
}

aq_snapshot_tag() {
  local existing=${1:-}
  local newname=${2:-}
  [ -z "$existing" ] && stderr 'Error: existing tag required: `aq snapshot tag <existing> <new>`.' && exit 1
  [ -z "$newname" ]  && stderr 'Error: new alias name required: `aq snapshot tag <existing> <new>`.' && exit 1

  local resolved
  resolved=$(resolve_tag "$existing") || {
    stderr "Error: snapshot or alias '$existing' does not exist."
    exit 1
  }

  if snapshot_exists "$newname"; then
    stderr "Error: '$newname' is itself a snapshot tag. Pick a different alias name."
    exit 1
  fi

  mkdir -p "$(tags_dir)"
  local link
  link=$(tag_path "$newname")
  ln -sfn "../../snapshots/$ARCH/$resolved" "$link"
  stderr "Tag '$newname' -> snapshot '$resolved'"
}

# Internal: indented one-line rendering. Args: <edges-file> <tag> <depth>.
_render_subtree() {
  local edges=$1 tag=$2 depth=$3
  local indent=""
  local i=0
  while [ $i -lt $depth ]; do
    indent="$indent    "
    i=$((i + 1))
  done

  local refs size last
  refs=$(get_refcount "$tag")
  size=$(du -h "$(snapshot_path "$tag")/disk.qcow2" 2>/dev/null | awk '{print $1}')
  last=$(read_meta "$tag" last_used 2>/dev/null | cut -dT -f1)
  printf '%s└── %s   [refs: %s, %s, %s]\n' "$indent" "$tag" "$refs" "${size:-?}" "${last:-?}"

  awk -F'\t' -v p="$tag" '$1 == p { print $2 }' "$edges" | while read -r child; do
    _render_subtree "$edges" "$child" "$((depth + 1))"
  done
}

aq_snapshot_tree() {
  local root=${1:-}
  local dir
  dir=$(snapshots_dir)
  [ -d "$dir" ] || { stderr "No snapshots."; return 0; }

  local edges
  edges=$(mktemp)

  set +f
  for snap_dir in "$dir"/*/; do
    [ -d "$snap_dir" ] || continue
    local tag parent
    tag=$(basename "$snap_dir")
    parent=$(read_meta "$tag" parent 2>/dev/null || echo "?")
    printf '%s\t%s\n' "$parent" "$tag" >> "$edges"
  done
  set -f

  if [ -n "$root" ]; then
    if ! snapshot_exists "$root"; then
      rm -f "$edges"
      stderr "Error: snapshot '$root' does not exist."
      exit 1
    fi
    _render_subtree "$edges" "$root" 0
  else
    echo "base (alpine-$LATEST_ALPINE_VERSION-$ARCH)"
    awk -F'\t' '$1 == "base" { print $2 }' "$edges" | while read -r child; do
      _render_subtree "$edges" "$child" 1
    done
  fi

  rm -f "$edges"
}

aq_snapshot() {
  local sub=${1:-}
  shift || true
  case "$sub" in
    create) aq_snapshot_create "$@" ;;
    ls)     aq_snapshot_ls "$@" ;;
    rm)     aq_snapshot_rm "$@" ;;
    tag)    aq_snapshot_tag "$@" ;;
    tree)   aq_snapshot_tree "$@" ;;
    *)
      stderr "Usage: aq snapshot {create|ls|rm|tag|tree} ..."
      exit 1
      ;;
  esac
}

aq_fanout() {
  local tag=""
  local n=""
  local keep=0
  local prefix=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --keep) keep=1; shift ;;
      --prefix=*) prefix="${1#--prefix=}"; shift ;;
      --prefix) prefix="$2"; shift; shift ;;
      --) shift; break ;;
      *)
        if [ -z "$tag" ]; then
          tag="$1"; shift
        elif [ -z "$n" ]; then
          n="$1"; shift
        else
          break
        fi
        ;;
    esac
  done

  [ -z "$tag" ] && { stderr 'Usage: aq fanout <tag> <N> [--keep] [--prefix=<name>] -- <command...>'; exit 1; }
  [ -z "$n" ]   && { stderr 'Usage: aq fanout <tag> <N> [--keep] [--prefix=<name>] -- <command...>'; exit 1; }
  [ $# -eq 0 ]  && { stderr 'Usage: aq fanout <tag> <N> [--keep] [--prefix=<name>] -- <command...>'; exit 1; }

  if ! [ "$n" -gt 0 ] 2>/dev/null; then
    stderr "Error: N must be a positive integer (got '$n')."; exit 1
  fi

  if ! resolve_tag "$tag" >/dev/null; then
    stderr "Error: snapshot or alias '$tag' does not exist."; exit 1
  fi

  [ -z "$prefix" ] && prefix="shard-$$"

  stderr "[fanout] creating $n VM(s) from snapshot '$tag' as '$prefix-0..$prefix-$((n-1))'"
  aq_new --from-snapshot="$tag" --count="$n" "$prefix" >/dev/null

  if [ "$keep" -eq 0 ]; then
    trap "_aq_fanout_cleanup '$prefix' '$n'" EXIT
  fi

  stderr "[fanout] starting all $n shards in parallel"
  local i=0
  while [ $i -lt $n ]; do
    "$0" start "$prefix-$i" >/dev/null 2>&1 &
    i=$((i + 1))
  done
  wait

  stderr "[fanout] dispatching command to $n shards"
  local cmd=("$@")
  local pids=()
  local exit_files=()
  i=0
  while [ $i -lt $n ]; do
    local exit_file
    exit_file=$(mktemp)
    exit_files+=("$exit_file")
    (
      # set +e: a non-zero exit from the user's command must NOT skip writing
      # the exit code to disk. >| forces overwrite under noclobber (set -C).
      set +e
      _aq_fanout_run_shard "$prefix" "$i" "$n" "${cmd[@]}"
      echo $? >| "$exit_file"
    ) &
    pids+=($!)
    i=$((i + 1))
  done
  wait "${pids[@]}" 2>/dev/null || true

  local max_exit=0
  i=0
  while [ $i -lt $n ]; do
    local code
    code=$(cat "${exit_files[$i]}" 2>/dev/null || echo 1)
    rm -f "${exit_files[$i]}"
    [ "$code" -gt "$max_exit" ] && max_exit=$code
    i=$((i + 1))
  done

  stderr "[fanout] all shards finished (max exit $max_exit)"
  exit "$max_exit"
}

# Run user command in one shard via SSH with AQ_SHARD_INDEX/AQ_SHARD_TOTAL,
# prefixing every output line with [<vm>].
#
# The command runs through `sh -s` reading from ssh stdin. We send "export"
# lines before the user command so that the user's command (which may
# contain $AQ_SHARD_INDEX literally) sees the variables when it parses.
# Using `VAR=val cmd` inline doesn't work here because $VAR in the same
# command line is expanded by the parent shell before the assignment
# takes effect for the child (classic POSIX gotcha).
_aq_fanout_run_shard() {
  local prefix=$1 i=$2 total=$3
  shift 3
  local vm="$prefix-$i"
  {
    printf 'export AQ_SHARD_INDEX=%s\n' "$i"
    printf 'export AQ_SHARD_TOTAL=%s\n' "$total"
    printf '%s\n' "$*"
  } | vm_ssh "$vm" 'sh -s' 2>&1 \
    | awk -v tag="$vm" '{ print "[" tag "] " $0 }'
  return ${PIPESTATUS[1]}
}

# Stop and remove every shard in the fleet. Args: <prefix> <count>.
_aq_fanout_cleanup() {
  local prefix=$1 n=$2
  local i=0
  while [ $i -lt $n ]; do
    "$0" rm "$prefix-$i" >/dev/null 2>&1 &
    i=$((i + 1))
  done
  wait
}

aq_ls() {
  [ ! -d "$BASE_DIR" ] && return 0

  (
    cd "$BASE_DIR"
    for vm_dir in $(ls); do
      [ ! -d "$vm_dir" ] && continue
      # Skip per-arch metadata directories and snapshot infrastructure
      case "$vm_dir" in
        aarch64|x86_64|snapshots|tags) continue ;;
      esac
      vm_name=$(basename "$vm_dir")
      if is_vm_running "$vm_name"; then
        status="On"
      else
        status="Off"
      fi

      # Get SSH port if available
      ssh_port=""
      if [ -f "$vm_dir/ssh-port.conf" ]; then
        ssh_port=$(cat "$vm_dir/ssh-port.conf")
        ssh_port=":$ssh_port"
      fi

      printf "%-20s %-4s %s\n" "$vm_name" "$status" "$ssh_port"
    done
  )
}

# Sourced-only mode: tests source this file just to call helpers.
# Defined functions remain available; dispatch is skipped.
if [ "${__AQ_SOURCED_ONLY:-0}" = "1" ]; then
  return 0 2>/dev/null || exit 0
fi

[ $# -gt 0 ] && { COMMAND=$1; shift; } || COMMAND=""
case $COMMAND in
  new) aq_new "$@" ;;
  start) aq_start "$@" ;;
  stop) aq_stop "$@" ;;
  console) aq_console "$@" ;;
  exec) aq_exec "$@" ;;
  scp) aq_scp "$@" ;;
  rm) aq_rm "$@" ;;
  ls) aq_ls ;;
  snapshot) aq_snapshot "$@" ;;
  fanout) aq_fanout "$@" ;;
  "--version") aq_version ;;
  "" | "help" | "-h" | "--help") aq_help ;;
  *) stderr "Error: Unknown command $COMMAND."; exit 1 ;;
esac

exit 0
